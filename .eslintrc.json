{
    "env": {
        "browser": true,
        "es6": true
    },
    "extends": [
        "plugin:vue/vue3-recommended"
    ],
    "rules": {
        "quotes": [2, "single", { "avoidEscape": true }],
        "indent": ["error", 4],
        "vue/html-indent": ["error", 4, {
            "attribute": 1,
            "baseIndent": 1,
            "closeBracket": 0,
            "alignAttributesVertically": true,
            "ignores": []
          }]
    }
}